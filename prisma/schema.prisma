generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String
  order     Int
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  price       Int
  badge       String?
  variantTag  String?
  description String?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order       Int
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Admin {
  id        String       @id @default(cuid())
  username  String       @unique
  password  String
  tokens    AdminToken[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AdminToken {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Order {
  id               String       @id @default(cuid())
  orderId          String       @unique
  customerName     String?
  customerPhone    String?
  subtotal         Int
  gst              Int
  packagingCharge  Int          @default(0)
  deliveryCharge   Int          @default(0)
  discount         Int          @default(0)
  couponCode       String?
  grandTotal       Int
  status           String       @default("PENDING")
  paymentMethod    String       @default("UPI")
  upiTransactionRef String?
  notes            String?
  items            OrderItem[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name      String
  price     Int
  quantity  Int
  total     Int
}

model RestaurantSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  discount    Int
  type        String    @default("FLAT")
  minOrder    Int       @default(0)
  maxUses     Int       @default(0)
  usedCount   Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

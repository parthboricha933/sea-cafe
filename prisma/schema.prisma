generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model MenuCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  icon      String
  order     Int
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  price       Int
  badge       String?
  variantTag  String?
  description String?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  order       Int
  isAvailable Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Admin {
  id        String       @id @default(cuid())
  username  String       @unique
  password  String
  tokens    AdminToken[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model AdminToken {
  id        String   @id @default(cuid())
  adminId   String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
}
